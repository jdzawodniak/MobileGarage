# Copy this file to .env in this folder (print-service/) and edit.
# Full installation: ../INSTALL.md

# Base URL of your inventory server (no trailing slash).
# Same PC: http://127.0.0.1:3011. Other PC / LAN: that machine's IP or hostname.
API_URL=http://127.0.0.1:3011

# Optional: if your server requires an API key
# API_KEY=your-secret-key

# Exact Windows printer names (Settings → Printers & scanners).
# DYMO Twin Turbo appears as two logical printers; set both for left/right roll choice on Add Item.
LARGE_PRINTER=Large Label Printer
SMALL_PRINTER=DYMO LabelWriter 450 Twin Turbo (Left)
SMALL_PRINTER_LEFT=DYMO LabelWriter 450 Twin Turbo (Left)
SMALL_PRINTER_RIGHT=DYMO LabelWriter 450 Twin Turbo (Right)

# --- Small (item) labels: print directly to DYMO (no Notepad) ---
# Set this to the full path of your .label file. The service will use Python + DYMO COM to open the
# template, set field1 = item name and field2 = location code, and print to the chosen roll (left/right/both).
# Create the label in DYMO Label software with two variable text objects named exactly: field1, field2.
DYMO_LABEL_PATH=E:\TestLabel2.label
# Optional: use a specific Python (e.g. project venv). Default: python from PATH.
# DYMO_PYTHON_PATH=E:\VSCodeProjects\Mobile_Garage\.venv\Scripts\python.exe
# Optional: project root (auto-detected if you start the service from project root or print-service/).
# MOBILE_GARAGE_ROOT=E:\VSCodeProjects\Mobile_Garage

# --- Alternative: DymoPrint CLI (if you prefer the DLS CLI instead of Python) ---
# DYMO_CLI_PATH=bin\DymoPrint.exe
# DYMO_LABEL_TEMPLATE=C:\path\to\item.label
# DYMO_OBJNAME_ITEM=ItemName
# DYMO_OBJNAME_LOCATION=Location

# How often to check for new jobs (milliseconds). Default 5000.
# POLL_INTERVAL_MS=5000
